{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./src",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@components/*": ["components/*"],
      "@constants/*": ["constants/*"],
      "@images/*": ["images/*"],
      "@app-types/*": ["types/*"],
      "@services/*": ["services/*"],
      "@scan/*": ["scan/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
